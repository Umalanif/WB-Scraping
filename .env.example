# ===========================================
# Wildberries Parser Configuration
# ===========================================

# ===========================================
# DATABASE CONFIGURATION (Prisma + SQLite)
# ===========================================

# SQLite database location for Prisma ORM
# The database file will be created in the storage directory
DATABASE_URL="file:./storage/dev.db"

# ===========================================
# MINER.JS SETTINGS
# ===========================================

# Run browser in headless mode (true/false)
# Set to false for visual debugging
HEADLESS=true

# ===========================================
# PARSER.JS SETTINGS
# ===========================================

# Maximum pages to scrape per query
MAX_PAGES=5

# Export results to JSON file (true/false)
OUTPUT_JSON=false

# Maximum retry attempts when rate limited (429/CAPTCHA)
MAX_RETRIES=3

# Base delay in ms for exponential backoff on retries
# Delay = BASE_DELAY * 2^(retry-1): 5s, 10s, 20s, 40s...
BASE_DELAY=5000

# Delay in ms between successful page requests
# Increase if you get 429 errors frequently
REQUEST_DELAY=3000

# ===========================================
# LOGGING SETTINGS
# ===========================================

# Log level: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# ===========================================
# USAGE EXAMPLES
# ===========================================

# Run miner (headless):
# npm run miner:headless

# Run miner (visible browser for debugging):
# cross-env HEADLESS=false npm run miner

# Run parser with default query "товар":
# npm run parser

# Run parser with custom query and limit:
# node parser.js "кроссовки" 50

# Run parser with JSON export:
# npm run parser:json
