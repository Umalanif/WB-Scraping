# ===========================================
# Wildberries Parser Configuration
# ===========================================

# ===========================================
# MINER.JS SETTINGS
# ===========================================

# Run browser in headless mode (true/false)
# Set to false for visual debugging
HEADLESS=true

# ===========================================
# PARSER.JS SETTINGS
# ===========================================

# Maximum pages to scrape per query
MAX_PAGES=5

# Export results to JSON file (true/false)
OUTPUT_JSON=false

# ===========================================
# LOGGING SETTINGS
# ===========================================

# Log level: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# ===========================================
# USAGE EXAMPLES
# ===========================================

# Run miner (headless):
# npm run miner:headless

# Run miner (visible browser for debugging):
# cross-env HEADLESS=false npm run miner

# Run parser with default query "товар":
# npm run parser

# Run parser with custom query and limit:
# node parser.js "кроссовки" 50

# Run parser with JSON export:
# npm run parser:json
