# ===========================================
# Wildberries Parser Configuration
# ===========================================

# ===========================================
# DATABASE CONFIGURATION (Prisma + SQLite)
# ===========================================

# SQLite database location for Prisma ORM
DATABASE_URL="file:dev.db"

# ===========================================
# MINER.JS SETTINGS
# ===========================================

# Run browser in headless mode (true/false)
# Set to false for visual debugging
HEADLESS=true

# ===========================================
# PARSER.JS SETTINGS
# ===========================================

# Maximum pages to scrape per query
MAX_PAGES=5

# Export results to JSON file (true/false)
OUTPUT_JSON=false

# Maximum retry attempts when rate limited (429/CAPTCHA)
MAX_RETRIES=3

# Base delay in ms for exponential backoff on retries
# Delay = BASE_DELAY * 2^(retry-1): 5s, 10s, 20s, 40s...
BASE_DELAY=5000

# Delay in ms between successful page requests
# Increase if you get 429 errors frequently
REQUEST_DELAY=3000

# ===========================================
# WORKER SETTINGS (Phase 2.2)
# ===========================================

# Rate limiting for worker (requests per second)
# Default: 2 RPS to avoid triggering WB anti-bot
RATE_LIMIT_RPS=2

# WB authentication cookie (required for API access)
# Obtain from browser session: x_wbaas_token=...
WB_COOKIE="x_wbaas_token=YOUR_TOKEN_HERE"

# WB API Base URL
WB_API_BASE="https://basket-09.wbbasket.ru"

# Price drop threshold for alerts (percentage)
# Alert triggered when price drops by this % or more
PRICE_DROP_THRESHOLD=10

# Proxy list (comma or newline separated, optional)
# Formats: http://user:pass@host:port or host:port
# Example: PROXY_LIST="http://user:pass@proxy1.com:8080,http://user:pass@proxy2.com:8080"
PROXY_LIST=""

# ===========================================
# TELEGRAM ALERTING (Phase 2.3)
# ===========================================

# Telegram bot token for sending alerts
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=""

# Telegram chat ID to receive alerts
# Get from @userinfobot: https://t.me/userinfobot
TELEGRAM_CHAT_ID=""

# ===========================================
# LOGGING SETTINGS
# ===========================================

# Log level: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# ===========================================
# USAGE EXAMPLES
# ===========================================

# Run miner (headless):
# npm run miner:headless

# Run miner (visible browser for debugging):
# cross-env HEADLESS=false npm run miner

# Run parser with default query "товар":
# npm run parser

# Run parser with custom query and limit:
# node parser.js "кроссовки" 50

# Run parser with JSON export:
# npm run parser:json
